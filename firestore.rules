rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read their own profile doc.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // All other data is server-only (admin SDK via the Cloud Function).
    // The Cloud Function uses ADC credentials which bypass these rules.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
