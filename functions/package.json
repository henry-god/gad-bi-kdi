{
  "name": "kgd-functions",
  "version": "0.1.0",
  "private": true,
  "description": "Firebase Functions entrypoint for the KGD Express API (/api/**)",
  "main": "dist/functions/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc -p .",
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "deploy": "firebase deploy --only functions:api --project=gad-bi-kdi"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.3.0",
    "@google/genai": "^1.50.0",
    "@prisma/client": "^6.19.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.0",
    "express-async-errors": "^3.1.1",
    "firebase-admin": "^12.1.0",
    "firebase-functions": "^5.0.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "prisma": "^6.19.3",
    "typescript": "^5.4.0"
  }
}
