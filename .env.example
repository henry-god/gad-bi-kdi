# === KGD Environment Variables ===
# Copy to .env.local and fill in values

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
FIREBASE_ADMIN_SERVICE_ACCOUNT=  # path to service account JSON

# Database
DATABASE_URL=postgresql://kgd_admin:dev_password_change_me@localhost:5432/khmer_gov_docs

# Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kgd-documents

# AI Services
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ChromaDB (Knowledge Vector Store)
CHROMA_URL=http://localhost:8000

# App
PORT=4000
NODE_ENV=development
