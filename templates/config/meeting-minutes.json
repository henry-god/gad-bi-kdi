      "required": true,
      "order": 3
    },
    {
      "id": "location",
      "label": "Location",
      "labelKm": "ទីកន្លែង",
      "type": "text",
      "required": true,
      "order": 4
    },
    {
      "id": "chairperson",
      "label": "Chairperson",
      "labelKm": "ប្រធានកិច្ចប្រជុំ",
      "type": "text",
      "required": true,
      "order": 5
    },
    {
      "id": "attendees",
      "label": "Attendees",
      "labelKm": "អ្នកចូលរួម",
