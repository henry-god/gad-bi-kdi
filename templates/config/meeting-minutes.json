      "required": true,
      "order": 6
    },
    {
      "id": "agenda",
      "label": "Agenda",
      "labelKm": "របៀបវារៈ",
      "type": "richtext",
      "required": true,
      "order": 7
    },
    {
      "id": "discussions",
      "label": "Discussions",
      "labelKm": "ការពិភាក្សា",
      "type": "richtext",
      "required": true,
      "order": 8
    },
    {
      "id": "decisions",
      "label": "Decisions",
      "labelKm": "សេចក្តីសម្រេច",
      "type": "richtext",
      "required": true,
      "order": 9
    },
    {
      "id": "action_items",
      "label": "Action Items",
      "labelKm": "ផែនការសកម្មភាព",
