      "required": true,
      "order": 1
    },
    {
      "id": "meeting_title",
      "label": "Meeting Title",
      "labelKm": "ចំណងជើងកិច្ចប្រជុំ",
      "type": "text",
      "required": true,
      "order": 2
    },
    {
      "id": "date",
