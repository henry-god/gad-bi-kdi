      "bottom": 2.54,
      "left": 3.17,
      "right": 2.54
    }
  },
  "fonts": {
    "title": {
      "family": "Khmer OS Siemreap",
      "size": 14,
      "bold": true
    },
    "body": {
      "family": "Khmer OS Siemreap",
      "size": 11,
