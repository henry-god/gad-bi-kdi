    "{{LOCATION}}": "Meeting location",
    "{{CHAIRPERSON}}": "Chairperson name and title",
    "{{ATTENDEES_TABLE}}": "Table of attendees",
    "{{AGENDA}}": "Meeting agenda items",
    "{{DISCUSSIONS}}": "Discussion summary",
    "{{DECISIONS}}": "Decisions made",
    "{{ACTION_ITEMS_TABLE}}": "Action items with assignees and deadlines",
    "{{PREPARED_BY}}": "Note taker name",
    "{{APPROVED_BY}}": "Approver name and title"
