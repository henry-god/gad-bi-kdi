{
  "id": "official-letter",
  "name": "Official Letter",
  "nameKm": "លិខិតផ្លូវការ",
  "category": "letter",
  "page": {
    "size": "A4",
    "orientation": "portrait",
    "margins": {
      "top": 2.54,
      "bottom": 2.54,
      "left": 3.17,
      "right": 2.54
    }
  },
  "fonts": {
    "title": {
      "family": "Khmer OS Siemreap",
      "size": 14,
      "bold": true
    },
    "body": {
      "family": "Khmer OS Siemreap",
      "size": 11,
      "lineSpacing": 1.5
    },
    "header": {
      "family": "Khmer OS Muollight",
      "size": 11
    },
    "footer": {
      "family": "Khmer OS Siemreap",
      "size": 9
    }
  },
  "letterhead": {
    "enabled": true,
    "logoPosition": "center",
    "ministryName": true,
    "departmentName": true,
    "emblem": true
  },
  "footer": {
    "enabled": true,
    "pageNumber": true,
    "address": true
  },
  "sections": [
    {
      "id": "header_kingdom",
      "label": "Kingdom Header",
      "labelKm": "បរិយាកាសនៃព្រះរាជាណាចក្រ",
      "type": "text",
      "required": true,
      "order": 1
    },
    {
      "id": "ref_number",
      "label": "Reference Number",
      "labelKm": "លេខយោង",
      "type": "text",
      "required": true,
      "order": 2
    },
    {
      "id": "date",
      "label": "Date",
      "labelKm": "កាលបរិច្ឆេទ",
      "type": "date",
      "required": true,
      "order": 3
    },
    {
      "id": "recipient",
      "label": "To",
      "labelKm": "ជូនចំពោះ",
      "type": "text",
      "required": true,
      "order": 4
    },
    {
      "id": "subject",
      "label": "Subject",
      "labelKm": "កម្មវត្ថុ",
      "type": "text",
      "required": true,
      "order": 5
    },
    {
      "id": "salutation",
      "label": "Salutation",
      "labelKm": "សេចក្តីថ្លែង",
      "type": "text",
      "required": true,
      "order": 6
    },
    {
      "id": "body",
      "label": "Body",
      "labelKm": "សេចក្តីលម្អិត",
      "type": "richtext",
      "required": true,
      "order": 7
    },
    {
      "id": "closing",
      "label": "Closing",
      "labelKm": "សេចក្តីបញ្ចប់",
      "type": "text",
      "required": true,
      "order": 8
    },
    {
      "id": "signature",
      "label": "Signature Block",
      "labelKm": "ហត្ថលេខា",
      "type": "signature",
      "required": true,
      "order": 9
    },
    {
      "id": "cc",
      "label": "CC",
      "labelKm": "ចម្លង",
      "type": "text",
      "required": false,
      "order": 10
    }
  ],
  "placeholders": {
    "{{KINGDOM_HEADER}}": "Kingdom of Cambodia header block",
    "{{MINISTRY_NAME}}": "Ministry name in Khmer",
    "{{DEPARTMENT_NAME}}": "Department/authority name",
    "{{REF_NUMBER}}": "Document reference number",
    "{{DATE}}": "Date in Khmer format",
    "{{RECIPIENT}}": "Recipient name and title",
    "{{SUBJECT}}": "Document subject line",
    "{{BODY}}": "Main content",
    "{{SIGNER_NAME}}": "Signer full name",
    "{{SIGNER_TITLE}}": "Signer official title",
    "{{CC_LIST}}": "Carbon copy recipients"
  }
}
