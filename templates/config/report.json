{
  "id": "report",
  "name": "Report",
  "nameKm": "របាយការណ៍",
  "category": "report",
  "page": {
    "size": "A4",
    "orientation": "portrait",
    "margins": {
      "top": 2.54,
      "bottom": 2.54,
      "left": 3.17,
      "right": 2.54
    }
  },
  "fonts": {
    "title": {
      "family": "Khmer OS Siemreap",
      "size": 14,
      "bold": true
    },
    "body": {
      "family": "Khmer OS Siemreap",
      "size": 11,
      "lineSpacing": 1.5
    },
    "header": {
      "family": "Khmer OS Muollight",
      "size": 11
    },
    "footer": {
      "family": "Khmer OS Siemreap",
      "size": 9
    }
  },
  "letterhead": {
    "enabled": true,
    "logoPosition": "center",
    "ministryName": true,
    "departmentName": true,
    "emblem": true
  },
  "footer": {
    "enabled": true,
    "pageNumber": true,
    "address": false
  },
  "sections": [
    {
      "id": "header_kingdom",
      "label": "Kingdom Header",
      "labelKm": "ក្បាលរាជាណាចក្រ",
      "type": "text",
      "required": true,
      "order": 1
    },
    {
      "id": "ref_number",
      "label": "Reference Number",
      "labelKm": "លេខយោង",
      "type": "text",
      "required": true,
      "order": 2
    },
    {
      "id": "date",
      "label": "Date",
      "labelKm": "កាលបរិច្ឆេទ",
      "type": "date",
      "required": true,
      "order": 3
    },
    {
      "id": "subject",
      "label": "Subject",
      "labelKm": "កម្មវត្ថុ",
      "type": "text",
      "required": true,
      "order": 4
    },
    {
      "id": "body",
      "label": "Body",
      "labelKm": "ខ្លឹមសារ",
      "type": "richtext",
      "required": true,
      "order": 5
    },
    {
      "id": "signature",
      "label": "Signature",
      "labelKm": "ហត្ថលេខា",
      "type": "signature",
      "required": true,
      "order": 6
    }
  ],
  "placeholders": {
    "{{REF_NUMBER}}": "Reference number",
    "{{DATE}}": "Date in Khmer format",
    "{{SUBJECT}}": "Subject line",
    "{{BODY}}": "Main content",
    "{{SIGNER_NAME}}": "Signer name",
    "{{SIGNER_TITLE}}": "Signer title"
  }
}
