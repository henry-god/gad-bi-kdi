{
  "id": "internal-memo",
  "name": "Internal Memo",
  "nameKm": "អនុស្សរណៈផ្ទៃក្នុង",
  "category": "memo",
  "page": {
    "size": "A4",
    "orientation": "portrait",
    "margins": {
      "top": 2.54,
      "bottom": 2.54,
      "left": 3.17,
      "right": 2.54
    }
  },
  "fonts": {
    "title": {
      "family": "Khmer OS Siemreap",
      "size": 14,
      "bold": true
    },
    "body": {
      "family": "Khmer OS Siemreap",
      "size": 11,
      "lineSpacing": 1.5
    },
    "header": {
      "family": "Khmer OS Muollight",
      "size": 11
    },
    "footer": {
      "family": "Khmer OS Siemreap",
      "size": 9
    }
  },
  "letterhead": {
    "enabled": true,
    "logoPosition": "center",
    "ministryName": true,
    "departmentName": true,
    "emblem": true
  },
  "footer": {
    "enabled": false,
    "pageNumber": true,
    "address": false
  },
  "sections": [
    {
      "id": "header_kingdom",
      "label": "Kingdom Header",
      "labelKm": "ក្បាលរាជាណាចក្រ",
      "type": "text",
      "required": true,
      "order": 1
    },
    {
      "id": "memo_number",
      "label": "Memo Number",
      "labelKm": "លេខអនុស្សរណៈ",
      "type": "text",
      "required": true,
      "order": 2
    },
    {
      "id": "date",
      "label": "Date",
      "labelKm": "កាលបរិច្ឆេទ",
      "type": "date",
      "required": true,
      "order": 3
    },
    {
      "id": "from",
      "label": "From",
      "labelKm": "ពី",
      "type": "text",
      "required": true,
      "order": 4
    },
    {
      "id": "to",
      "label": "To",
      "labelKm": "ជូន",
      "type": "text",
      "required": true,
      "order": 5
    },
    {
      "id": "subject",
      "label": "Subject",
      "labelKm": "កម្មវត្ថុ",
      "type": "text",
      "required": true,
      "order": 6
    },
    {
      "id": "body",
      "label": "Body",
      "labelKm": "ខ្លឹមសារ",
      "type": "richtext",
      "required": true,
      "order": 7
    },
    {
      "id": "action_required",
      "label": "Action Required",
      "labelKm": "សកម្មភាពត្រូវការ",
      "type": "text",
      "required": false,
      "order": 8
    },
    {
      "id": "signature",
      "label": "Signature",
      "labelKm": "ហត្ថលេខា",
      "type": "signature",
      "required": true,
      "order": 9
    }
  ],
  "placeholders": {
    "{{MEMO_NUMBER}}": "Memo reference number",
    "{{FROM}}": "Sender name and title",
    "{{TO}}": "Recipient name and title",
    "{{SUBJECT}}": "Memo subject",
    "{{BODY}}": "Main content",
    "{{ACTION}}": "Required actions",
    "{{SIGNER_NAME}}": "Signer name",
    "{{SIGNER_TITLE}}": "Signer title"
  }
}
