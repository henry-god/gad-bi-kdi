    { "id": "memo_number", "label": "Memo Number", "labelKm": "លេខកំណត់", "type": "text", "required": true, "order": 2 },
    { "id": "date", "label": "Date", "labelKm": "កាលបរិច្ឆេទ", "type": "date", "required": true, "order": 3 },
    { "id": "to", "label": "To", "labelKm": "ជូន", "type": "text", "required": true, "order": 4 },
    { "id": "from", "label": "From", "labelKm": "ពី", "type": "text", "required": true, "order": 5 },
    { "id": "subject", "label": "Subject", "labelKm": "កម្មវត្ថុ", "type": "text", "required": true, "order": 6 },
    { "id": "background", "label": "Background", "labelKm": "ប្រវត្តិរឿង", "type": "richtext", "required": true, "order": 7 },
    { "id": "findings", "label": "Findings", "labelKm": "ការរកឃើញ", "type": "richtext", "required": true, "order": 8 },
    { "id": "recommendation", "label": "Recommendation", "labelKm": "អនុសាសន៍", "type": "richtext", "required": true, "order": 9 },
    { "id": "signature", "label": "Signature", "labelKm": "ហត្ថលេខា", "type": "signature", "required": true, "order": 10 }
