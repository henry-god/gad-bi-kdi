    { "id": "title", "label": "Title", "labelKm": "ចំណងជើង", "type": "text", "required": true, "order": 2 },
    { "id": "period", "label": "Reporting Period", "labelKm": "រយៈពេលរាយការណ៍", "type": "text", "required": true, "order": 3 },
    { "id": "authors", "label": "Authors", "labelKm": "អ្នករៀបចំ", "type": "text", "required": true, "order": 4 },
    { "id": "summary", "label": "Executive Summary", "labelKm": "សេចក្តីសង្ខេប", "type": "richtext", "required": true, "order": 5 },
    { "id": "body", "label": "Main Sections", "labelKm": "មាតិកាសំខាន់", "type": "richtext", "required": true, "order": 6 },
    { "id": "conclusion", "label": "Conclusion", "labelKm": "សេចក្តីសន្និដ្ឋាន", "type": "richtext", "required": true, "order": 7 },
