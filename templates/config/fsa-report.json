  "placeholders": {
    "{{TITLE}}": "Report title",
    "{{PERIOD}}": "Reporting period",
    "{{AUTHORS}}": "Report authors",
    "{{SUMMARY}}": "Executive summary",
    "{{BODY}}": "Main report content",
    "{{CONCLUSION}}": "Conclusion",
    "{{SIGNER_NAME}}": "Signer name",
    "{{SIGNER_TITLE}}": "Signer title"
