{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "dom",
      "dom.iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/templates/*": [
        "./templates/*"
      ],
      "@/knowledge/*": [
        "./knowledge/*"
      ]
    },
    "outDir": "./dist",
    "allowJs": true,
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/frontend/**/*.ts",
    "src/frontend/**/*.tsx",
    "src/shared/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/backend",
    "src/ai",
    "scripts",
    "prisma",
    "tests"
  ]
}
