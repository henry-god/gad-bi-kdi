{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "storage/**",
      "output/**",
      "tests/**",
      "docs/**",
      "functions/**"
    ],
    "frameworksBackend": {
      "region": "asia-southeast1"
    },
    "rewrites": [
      {
        "source": "/api/**",
        "function": { "functionId": "api", "region": "asia-southeast1" }
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "api",
      "runtime": "nodejs20",
      "ignore": ["node_modules", ".git"]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "hosting": { "port": 5000 },
    "auth":    { "port": 9099 },
    "storage": { "port": 9199 },
    "ui":      { "enabled": true, "port": 4040 },
    "singleProjectMode": true
  }
}
