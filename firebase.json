{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "storage/**",
      "output/**",
      "tests/**",
      "docs/**"
    ],
    "frameworksBackend": {
      "region": "asia-southeast1"
    },
    "rewrites": [
      {
        "source": "/api/**",
        "run": { "serviceId": "ssrgadbikdi", "region": "asia-southeast1" }
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "hosting": { "port": 5000 },
    "auth":    { "port": 9099 },
    "storage": { "port": 9199 },
    "ui":      { "enabled": true, "port": 4040 },
    "singleProjectMode": true
  }
}
