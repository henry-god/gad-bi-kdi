{
  "name": "khmer-gov-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Khmer Government Document Intelligence Platform",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "api": "tsx watch src/backend/server.ts",
    "api:build": "tsc -p tsconfig.server.json",
    "test": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "seed": "tsx scripts/seed-knowledge.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "generate:template": "tsx scripts/generate-from-template.ts"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.3.0",
    "@google/genai": "^1.50.0",
    "@prisma/client": "^6.19.3",
    "chromadb": "^3.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.0",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.1.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "next": "^14.2.0",
    "prisma": "^6.19.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
